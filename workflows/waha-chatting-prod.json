      },
      "type": "n8n-nodes-base.set",
      "name": "Git Config Push",
      "position": [
        -320,
        1640
      ],
      "typeVersion": 3.4
    },
    {
      "parameters": {
        "url": "=http://localhost:5678/api/v1/workflows/{{ $json.workflowId }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "name": "GET Workflow from n8n",
      "position": [
        -100,
        1640
      ],
      "typeVersion": 4.2,
      "credentials": {
        "httpHeaderAuth": {
          "id": "",
          "name": "n8n API Key"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Get workflow data and config\nconst workflow = $input.first().json;\nconst config = $('Git Config Push').first().json;\n\n// Clean export: remove runtime fields\nconst exportData = { ...workflow };\ndelete exportData.statistics;\ndelete exportData.updatedAt;\ndelete exportData.createdAt;\n\nconst content = JSON.stringify(exportData, null, 2);\nconst contentBase64 = Buffer.from(content).toString('base64');\nconst timestamp = new Date().toISOString().slice(0, 19).replace('T', ' ');\n\nreturn [{\n  json: {\n    content: contentBase64,\n    message: `Update workflow: ${workflow.name} (${timestamp})`,\n    repoOwner: config.repoOwner,\n    repoName: config.repoName,\n    filePath: config.filePath,\n    branch: config.branch\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "name": "Prepare Push Payload",
      "position": [
        120,
        1640
      ],
      "typeVersion": 2
    },
    {
      "parameters": {
        "url": "=https://api.github.com/repos/{{ $json.repoOwner }}/{{ $json.repoName }}/contents/{{ $json.filePath }}?ref={{ $json.branch }}",

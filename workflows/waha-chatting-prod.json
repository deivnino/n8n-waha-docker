    {
      "parameters": {
        "mode": "raw",
        "jsonOutput": "{\"repoOwner\": \"deivnino\", \"repoName\": \"n8n-waha-docker\", \"filePath\": \"workflows/waha-chatting-prod.json\", \"branch\": \"main\", \"workflowId\": \"xXQ0R_KRA2teh7aVZe-kQ\"}",

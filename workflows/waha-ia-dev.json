    {
      "parameters": {
        "jsCode": "// Merge: business config (horarios) + customer state (status, is_vip)\nconst biz = $('Get Business Config').first().json;\nconst customer = $('Get Chat Control').first().json;\nconst merged = { ...biz, ...customer };\nconst bh = biz.business_hours;\n\n// Si business_hours no está configurado o outside_hours_enabled es false, siempre pasar\nif (!bh || !biz.outside_hours_enabled) {\n  return [{ json: { ...merged, within_hours: true } }];\n}\n\n// Hora actual en Colombia (GMT-5)\nconst now = new Date();\nconst colombiaOffset = -5 * 60;\nconst utcMinutes = now.getTime() / 60000 + now.getTimezoneOffset();\nconst colombiaDate = new Date((utcMinutes + colombiaOffset) * 60000);\n\nconst days = ['sunday','monday','tuesday','wednesday','thursday','friday','saturday'];\nconst dayName = days[colombiaDate.getDay()];\nconst currentHour = colombiaDate.getHours();\nconst currentMin = colombiaDate.getMinutes();\nconst currentTotal = currentHour * 60 + currentMin;\n\nconst schedule = bh.schedule || {};\nconst dayConfig = schedule[dayName];\n\nlet withinHours = false;\nif (dayConfig && dayConfig.enabled) {\n  const [openH, openM] = dayConfig.open.split(':').map(Number);\n  const [closeH, closeM] = dayConfig.close.split(':').map(Number);\n  const openTotal = openH * 60 + openM;\n  const closeTotal = closeH * 60 + closeM;\n  withinHours = currentTotal >= openTotal && currentTotal < closeTotal;\n}\n\nreturn [{ json: { ...merged, within_hours: withinHours, outside_message: bh.outside_message || 'Estamos fuera de horario. Te responderemos pronto.' } }];"
      },
      "id": "check-business-hours-v1",
      "name": "Check Business Hours",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1152,
        968

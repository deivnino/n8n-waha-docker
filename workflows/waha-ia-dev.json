    {
      "parameters": {
        "jsCode": "const workflow = $input.first().json;\nconst config = $('Git Config Push').first().json;\nconst exportData = { ...workflow };\ndelete exportData.statistics;\ndelete exportData.updatedAt;\ndelete exportData.createdAt;\nconst content = JSON.stringify(exportData, null, 2);\nconst timestamp = new Date().toISOString().slice(0, 19).replace('T', ' ');\nreturn [{\n  json: {\n    content: content,\n    message: `Update workflow: ${workflow.name} (${timestamp})`,\n    repoOwner: config.repoOwner,\n    repoName: config.repoName,\n    filePath: config.filePath,\n    branch: config.branch\n  }\n}];"
      },

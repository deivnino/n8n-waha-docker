        "jsCode": "// Parse GitHub response - read binary file from native GitHub node\nconst config = $('Git Config Pull').first().json;\n\n// Official n8n way to read binary data\nconst binaryBuffer = await this.helpers.getBinaryDataBuffer(0, 'data');\nconst rawContent = binaryBuffer.toString('utf8');\n\nconst workflowData = JSON.parse(rawContent);\n\n// Filter settings to only API-safe keys\nconst allowedSettings = ['executionOrder', 'callerPolicy', 'errorWorkflow', 'timezone'];\nconst safeSettings = {};\nfor (const key of allowedSettings) {\n  if (workflowData.settings && workflowData.settings[key] !== undefined) {\n    safeSettings[key] = workflowData.settings[key];\n  }\n}\n\nconst updatePayload = {\n  name: workflowData.name,\n  nodes: workflowData.nodes,\n  connections: workflowData.connections,\n  settings: safeSettings,\n  staticData: workflowData.staticData || null\n};\nreturn [{ json: { workflowId: config.workflowId, payload: updatePayload } }];"

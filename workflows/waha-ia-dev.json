        "name": "Consultar_Sitio_Web",
        "description": "Busca información específica en el sitio web del negocio usando extracción con IA (Firecrawl). Úsala cuando el usuario pregunte por productos, precios, disponibilidad o servicios y la base de conocimiento no tenga la respuesta. Pasa como input la consulta exacta del usuario.",
        "jsCode": "const config = $('Get Business Config').item.json;\nconst websiteUrl = config.website_url;\nif (!websiteUrl) return { error: 'No hay sitio web configurado para este negocio' };\nconst apiKey = $env.FIRECRAWL_API_KEY;\nif (!apiKey) return { error: 'Firecrawl no configurado — contacta al administrador' };\nconst userQuery = $input.first().json.query || $input.first().json.input || 'información general';\ntry {\n  const resp = await fetch('https://api.firecrawl.dev/v1/extract', {\n    method: 'POST',\n    headers: { 'Authorization': `Bearer ${apiKey}`, 'Content-Type': 'application/json' },\n    body: JSON.stringify({\n      urls: [websiteUrl],\n      prompt: `Extrae información relevante sobre: ${userQuery}. Incluye nombres de productos, precios, disponibilidad en stock y referencias o SKU si aplica.`,\n      schema: {\n        type: 'object',\n        properties: {\n          resultados: { type: 'array', items: { type: 'object', properties: { nombre: { type: 'string' }, precio: { type: 'string' }, disponibilidad: { type: 'string' }, referencia: { type: 'string' } } } },\n          resumen: { type: 'string' }\n        }\n      }\n    }),\n    signal: AbortSignal.timeout(15000)\n  });\n  const data = await resp.json();\n  if (!data.success) return { error: 'Firecrawl error: ' + (data.error || JSON.stringify(data)) };\n  return data.data || { resumen: 'Sin resultados' };\n} catch(e) { return { error: `Error al consultar el sitio: ${e.message}` }; }"
      },
      "id": "web-tool-node-v1",
      "name": "Consultar Sitio Web",
      "type": "@n8n/n8n-nodes-langchain.toolCode",
      "typeVersion": 1.1,
      "position": [
        2944,
        848
      ]
    },
    {
      "parameters": {
        "name": "Consultar_Inventario_ERP",
        "description": "Consulta el inventario en tiempo real del ERP del negocio (Allegra u otro sistema). Úsala cuando el usuario pregunte por disponibilidad de stock, precios exactos o referencias de productos específicos. Solo funciona si el cliente tiene configurada la integración de inventario.",
        "jsCode": "const config = $('Get Business Config').item.json;\nconst allegraUrl = config.allegra_url;\nconst allegraKey = config.allegra_api_key;\nif (!allegraUrl || !allegraKey) return { error: 'Inventario ERP no configurado para este negocio' };\nconst userQuery = $input.first().json.query || $input.first().json.input || '';\ntry {\n  const resp = await fetch(`${allegraUrl}/items?search=${encodeURIComponent(userQuery)}&limit=10`, {\n    headers: { 'Authorization': `Bearer ${allegraKey}`, 'Content-Type': 'application/json', 'Accept': 'application/json' },\n    signal: AbortSignal.timeout(8000)\n  });\n  if (!resp.ok) return { error: `ERP respondió con error ${resp.status}` };\n  const data = await resp.json();\n  return data;\n} catch(e) { return { error: `Error al consultar inventario: ${e.message}` }; }"
      },
